---
interface Props {
  id: string;
  class?: string;
}

const { id, class: className = "" } = Astro.props;
---

<div class="text-center">
  <h2 id={id} class:list={["text-3xl font-light text-gray-900", className]}>
    <div class="group inline-flex items-center gap-2">
      <slot />
      <a
        href={`#${id}`}
        class="text-gray-400 opacity-0 transition-opacity duration-200 group-hover:opacity-100 hover:text-gray-600"
        aria-label={`Link to ${id} section`}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
        </svg>
      </a>
    </div>
  </h2>
</div>
