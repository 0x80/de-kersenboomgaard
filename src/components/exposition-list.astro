---
import type { Artist, Exposition } from "../utils/content";
import { formatDateRange, formatDutchDate, parseTimeFormat } from "../utils/date-format";

interface Props {
  expositions: Exposition[];
  artists: Artist[];
}

const { expositions, artists } = Astro.props;
const artistsMap = Object.fromEntries(artists.map((a) => [a.id, a]));
---

<div class="mx-auto max-w-4xl space-y-8">
  {
    expositions.map((expo) => {
      const linkedArtists = expo.artistIds
        .map((id) => artistsMap[id])
        .filter((artist): artist is Artist => artist?.name !== undefined);

      return (
        <div class="space-y-3">
          <h3 class="text-xl font-medium text-gray-900">{expo.title}</h3>
          {linkedArtists.length > 0 && (
            <p class="text-sm text-gray-600">
              <span class="font-semibold">Kunstenaars:</span>{" "}
              {linkedArtists.map((artist, index) => (
                <>
                  <a
                    href={`#artist-${artist.id}`}
                    class="artist-scroll-link bg-gray-100 px-1 py-0.5 text-gray-900 hover:text-black hover:shadow-[0_3px_0_0_#374151]"
                  >
                    {artist.name}
                  </a>
                  {index < linkedArtists.length - 1 && ", "}
                </>
              ))}
            </p>
          )}
          <p class="text-sm font-medium text-gray-500">
            {formatDateRange(expo.startDate, expo.endDate, expo.startTime, expo.endTime)}
          </p>
          {expo.openingEventTime && (
            <p class="text-sm text-gray-600">
              <span class="font-semibold">Opening:</span>{" "}
              {formatDutchDate(expo.startDate)}
              {", "}
              {parseTimeFormat(String(expo.openingEventTime))}
              {expo.openingEventDescription && (
                <> &ndash; {expo.openingEventDescription}</>
              )}
            </p>
          )}
          <p class="text-sm text-gray-600">
            <span class="font-semibold">Locatie:</span> {expo.location},{" "}
            {expo.address}
          </p>
          {expo.content && (
            <p class="leading-relaxed text-gray-600">{expo.content}</p>
          )}
          {expo.link && (
            <p class="text-sm">
              <a
                href={expo.link}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-gray-100 px-2 py-1 text-gray-900 transition-all hover:text-black hover:shadow-[0_3px_0_0_#374151]"
              >
                Meer info
              </a>
            </p>
          )}
        </div>
      );
    })
  }
</div>

