---
import type { AgendaItem } from "../utils/content";
import { formatDateRange } from "../utils/date-format";

interface Props {
  agendaItems: AgendaItem[];
}

const { agendaItems } = Astro.props;
---

<div class="mx-auto max-w-4xl space-y-8">
  {
    agendaItems.map((item) => (
      <div class="space-y-3">
        <h3 class="text-xl font-medium text-gray-900">{item.title}</h3>
        <p class="text-sm font-medium text-gray-500">
          {formatDateRange(item.startDate, item.endDate, item.startTime, item.endTime)}
        </p>
        {item.content && <p class="leading-relaxed text-gray-600">{item.content}</p>}
        {item.eventLink && (
          <a
            href={item.eventLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block bg-gray-100 px-1 py-0.5 text-sm text-gray-900 hover:text-black hover:shadow-[0_3px_0_0_#374151]"
          >
            Meer info &rarr;
          </a>
        )}
      </div>
    ))
  }
</div>
