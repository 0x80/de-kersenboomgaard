---
import Layout from "../layouts/layout.astro";
import { getArtists, getCourses, getExpositions, getUpcomingExpositions } from "../utils/content";
import { getSEOData, generateStructuredData } from "../utils/seo";
import { formatDateRange, formatDutchDate, parseTimeFormat } from "../utils/date-format";
import type { Artist } from "../utils/content";

const artists = await getArtists();
const courses = await getCourses(artists);
const expositions = await getExpositions();
const upcomingExpositions = getUpcomingExpositions(expositions);

const seo = getSEOData(artists, courses);
const structuredData = generateStructuredData(artists, courses);

const artistsMap = Object.fromEntries(artists.map((a) => [a.id, a]));

const pageLinks = [
  { href: "/kunstenaars", label: "Kunstenaars", description: "Ontdek de kunstenaars, makers en creatievelingen" },
  { href: "/cursussen", label: "Cursussen & Workshops", description: "Creatieve cursussen en workshops" },
  { href: "/over-ons", label: "Over ons", description: "Over Ateliers Kersenboomgaard" },
  { href: "/contact", label: "Contact", description: "Neem contact met ons op" },
];
---

<Layout title={seo.title} description={seo.description} keywords={seo.keywords}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData.organization)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData.localBusiness)} />

  <div class="min-h-screen bg-white">
    <main>
      {upcomingExpositions.length > 0 && (
        upcomingExpositions.map((expo) => {
          const linkedArtists = expo.artistIds
            .map((id) => artistsMap[id])
            .filter((artist): artist is Artist => artist?.name !== undefined);

          return (
            <>
              {/* Mobile: flyer on top, text below */}
              <div class="lg:hidden pt-20">
                {expo.flyerImage && (
                  <div class="w-full">
                    <img
                      src={expo.flyerImage}
                      alt={expo.title}
                      class="w-full h-auto"
                      loading="eager"
                    />
                  </div>
                )}

                <div class="px-6 py-12">
                  <h2 class="text-2xl font-medium text-gray-900 mb-8">{expo.title}</h2>

                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-6 mb-12 text-sm">
                    <div>
                      <h3 class="text-xs uppercase tracking-widest text-gray-400 mb-2">Data</h3>
                      <p class="text-gray-700">{formatDateRange(expo.startDate, expo.endDate, expo.startTime, expo.endTime)}</p>
                    </div>

                    {expo.openingEventTime && (
                      <div>
                        <h3 class="text-xs uppercase tracking-widest text-gray-400 mb-2">Opening</h3>
                        <p class="text-gray-700">
                          {formatDutchDate(expo.startDate)}, {parseTimeFormat(String(expo.openingEventTime))}
                        </p>
                        {expo.openingEventDescription && (
                          <p class="text-gray-500 mt-1">{expo.openingEventDescription}</p>
                        )}
                      </div>
                    )}

                    <div>
                      <h3 class="text-xs uppercase tracking-widest text-gray-400 mb-2">Locatie</h3>
                      <p class="text-gray-700">{expo.location}</p>
                      <p class="text-gray-500 mt-1">{expo.address}</p>
                    </div>

                    {linkedArtists.length > 0 && (
                      <div>
                        <h3 class="text-xs uppercase tracking-widest text-gray-400 mb-2">Kunstenaars</h3>
                        <ul>
                          {linkedArtists.map((artist) => (
                            <li>
                              {artist.link ? (
                                <a href={artist.link} target="_blank" rel="noopener noreferrer" class="text-gray-700 hover:text-black hover:shadow-[0_1px_0_0_#374151]">{artist.name}</a>
                              ) : (
                                <span class="text-gray-700">{artist.name}</span>
                              )}
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </div>

                  {expo.content && (
                    <div class="leading-relaxed text-gray-600 space-y-4">
                      {expo.content.split("\n\n").map((paragraph) => (
                        <p>{paragraph}</p>
                      ))}
                    </div>
                  )}

                  {expo.link && (
                    <p class="mt-8 text-sm">
                      <a href={expo.link} target="_blank" rel="noopener noreferrer" class="bg-gray-100 px-2 py-1 text-gray-900 transition-all hover:text-black hover:shadow-[0_3px_0_0_#374151]">
                        Meer info
                      </a>
                    </p>
                  )}
                </div>
              </div>

              {/* Desktop: two-column layout */}
              <div class="hidden lg:block mx-auto max-w-6xl px-6 py-12 pt-24">
                <div class="grid grid-cols-2 gap-12 items-start">
                  <div>
                    <h2 class="text-2xl font-medium text-gray-900 mb-8">{expo.title}</h2>

                    <div class="space-y-6 mb-12 text-sm">
                      <div>
                        <h3 class="text-xs uppercase tracking-widest text-gray-400 mb-2">Data</h3>
                        <p class="text-gray-700">{formatDateRange(expo.startDate, expo.endDate, expo.startTime, expo.endTime)}</p>
                      </div>

                      {expo.openingEventTime && (
                        <div>
                          <h3 class="text-xs uppercase tracking-widest text-gray-400 mb-2">Opening</h3>
                          <p class="text-gray-700">
                            {formatDutchDate(expo.startDate)}, {parseTimeFormat(String(expo.openingEventTime))}
                          </p>
                          {expo.openingEventDescription && (
                            <p class="text-gray-500 mt-1">{expo.openingEventDescription}</p>
                          )}
                        </div>
                      )}

                      <div>
                        <h3 class="text-xs uppercase tracking-widest text-gray-400 mb-2">Locatie</h3>
                        <p class="text-gray-700">{expo.location}</p>
                        <p class="text-gray-500 mt-1">{expo.address}</p>
                      </div>

                      {linkedArtists.length > 0 && (
                        <div>
                          <h3 class="text-xs uppercase tracking-widest text-gray-400 mb-2">Kunstenaars</h3>
                          <ul>
                            {linkedArtists.map((artist) => (
                              <li>
                                {artist.link ? (
                                  <a href={artist.link} target="_blank" rel="noopener noreferrer" class="text-gray-700 hover:text-black hover:shadow-[0_1px_0_0_#374151]">{artist.name}</a>
                                ) : (
                                  <span class="text-gray-700">{artist.name}</span>
                                )}
                              </li>
                            ))}
                          </ul>
                        </div>
                      )}
                    </div>

                    {expo.content && (
                      <div class="leading-relaxed text-gray-600 space-y-4">
                        {expo.content.split("\n\n").map((paragraph) => (
                          <p>{paragraph}</p>
                        ))}
                      </div>
                    )}

                    {expo.link && (
                      <p class="mt-8 text-sm">
                        <a href={expo.link} target="_blank" rel="noopener noreferrer" class="bg-gray-100 px-2 py-1 text-gray-900 transition-all hover:text-black hover:shadow-[0_3px_0_0_#374151]">
                          Meer info
                        </a>
                      </p>
                    )}
                  </div>

                  {expo.flyerImage && (
                    <div>
                      <img
                        src={expo.flyerImage}
                        alt={expo.title}
                        class="w-full h-auto"
                        loading="eager"
                      />
                    </div>
                  )}
                </div>
              </div>
            </>
          );
        })
      )}

      {upcomingExpositions.length === 0 && (
        <div class="mx-auto max-w-6xl px-6 py-16 pt-24 text-center">
          <h2 class="text-2xl font-light text-gray-900">
            Ateliers Kersenboomgaard
          </h2>
          <p class="mt-4 text-gray-600">
            Kunstenaarscommunity in Utrecht met {artists.length}+ kunstenaars, makers en creatievelingen.
          </p>
        </div>
      )}

      {/* Page navigation links */}
      <div class="mx-auto max-w-6xl px-6 py-12">
        <div class="border-t border-gray-200 pt-12">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            {pageLinks.map((link) => (
              <a
                href={link.href}
                class="group block"
              >
                <h3 class="text-sm font-medium text-gray-900 group-hover:text-gray-600 transition-colors">
                  {link.label}
                </h3>
                <p class="mt-1 text-xs text-gray-400">
                  {link.description}
                </p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>
